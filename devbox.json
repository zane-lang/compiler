{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "just@latest",
    "meson@latest",
    "clang@latest",
    "cmake@latest",
    "antlr4@latest",
    "llvm_21@latest",
    "upx@latest",
    "ninja@latest",
    "zig@latest",
    "clang-tools@latest",
    "bison@latest",
    "re2c@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!'",
      "export PATH=$(realpath $DEVBOX_PROJECT_ROOT/bin):$PATH"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
