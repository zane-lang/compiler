package Main

import Random

struct Weapon {
name String
damage Float
}

struct Player {
health Float
currentWeapon Weapon
}

Float getHealth(player Player) => player.health

Void swapWeapon(player Player, newWeapon Weapon) {
player.currentWeapon = newWeapon
}

Float ? Void game() {
weapon Weapon = Weapon{
name: "Rifle",
damage: 20.0,
}
player Player = Player{
health: 100.0,
currentWeapon: weapon,
}
guard player.health ~= 100.0 {
abort
}
if Random$bool() {
swapWeapon(player, Weapon{name: "Shotgun", damage: 40.0})
} else {
swapWeapon(player, Weapon{name: "Pistol", damage: 10.0})
}
health Float = getHealth(player)
return health
}

Void main() {
health Float = spawn Main$game() ? {
resolve 0.0
}
println("Player health: " + health)
}
