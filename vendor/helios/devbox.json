{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "clang@latest",
    "clang-tools@latest",
    "llvm_21@latest",
    "ninja@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!'",
      "export LLVM_CONFIG=$(realpath $DEVBOX_PROJECT_ROOT/.devbox/nix/profile/default/bin/llvm-config)"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
